{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/webhook",
      "destination": "/api/index"
    },
    {
      "source": "/api/callback",
      "destination": "/api/index"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/index/cron",
      "schedule": "0 0 * * 1"
    }
  ]
}
